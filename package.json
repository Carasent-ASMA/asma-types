{
    "name": "asma-types",
    "version": "2.8.1",
    "description": "shared ts asma types",
    "main": "lib/index.js",
    "files": [
        "lib/**/*"
    ],
    "type": "module",
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
