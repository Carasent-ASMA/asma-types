    "license": "MIT",
    "scripts": {
        "build": "pnpm ts:check",
        "ts:check": "tsc",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Carasent-ASMA/asma-types"
    },
    "devDependencies": {
        "typescript": "7.0.2"
    }
}
